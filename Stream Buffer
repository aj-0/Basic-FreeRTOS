char txdata[10] = "AJ";
char rxdata[2];   /* FIX: size 2 — 1 data byte + null terminator, avoids overrun */

int __io_putchar(int ch)
{
    ITM_SendChar(ch);
    return ch;
}

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    BaseType_t xHigherPriorityTaskWoken = pdFALSE;
    vTaskNotifyGiveFromISR(htask_uart_send, &xHigherPriorityTaskWoken);  /* FIX: use correct handle */
    portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    BaseType_t xHigherPriorityTaskWoken = pdFALSE;

    /* FIX: send exactly 1 byte — only 1 byte was received per Receive_IT call */
    xStreamBufferSendFromISR(hsb, rxdata, 1, &xHigherPriorityTaskWoken);

    portYIELD_FROM_ISR(xHigherPriorityTaskWoken);

    /* Re-arm the receive interrupt for next byte */
    HAL_UART_Receive_IT(&huart2, (uint8_t*)rxdata, 1);
}

void rxprcs(void *argument)
{
    char sbuff[10];
    size_t bytes_received;
int c=-1;
    while (1)
    {
        /* FIX: xStreamBufferReceive returns number of bytes received (size_t), not a char.
                Read up to 9 bytes, null-terminate, then print the string. */
        bytes_received = xStreamBufferReceive(hsb, sbuff, sizeof(sbuff) - 1, portMAX_DELAY);
        if (bytes_received > 0)
        {c++;
            sbuff[bytes_received] = '\0';   /* null-terminate before printing */
            printf("%d . %s\n",c, sbuff);          /* FIX: print the buffer, not sbuff[l] */
        }
    }
}

void uart_send(void *argument)
{
    char uarttx[] = "prjt sucess!!!\r\n";

    while (1)
    {
        ulTaskNotifyTake(pdTRUE, portMAX_DELAY);
        HAL_UART_Transmit(&huart2, (uint8_t*)uarttx, strlen(uarttx), HAL_MAX_DELAY);
    }
}

