    /* USER CODE BEGIN 2 */

    hsb = xStreamBufferCreate(64, 1);   /* FIX: increased buffer to 64 bytes for safety */

    printf("printf testing done!!!\n");

    HAL_UART_Transmit(&huart2, (uint8_t*)txdata, strlen(txdata), HAL_MAX_DELAY);
    HAL_UART_Receive_IT(&huart2, (uint8_t*)rxdata, 1);

    /* FIX: each task gets its own handle; htask_uart_send is used by the EXTI ISR */
    xTaskCreate(uart_send, "UART_SEND", 256, NULL, 8, &htask_uart_send);
    xTaskCreate(rxprcs,    "RX_PRCS",   256, NULL, 5, &htask_rxprcs);

    /* USER CODE END 2 */

    vTaskStartScheduler();

    /* We should never get here */
    while (1) {}
}

