/* Stack overflow hook — fires when FreeRTOS detects overflow */
void vApplicationStackOverflowHook(TaskHandle_t xTask, char *pcTaskName)
{
    (void)xTask;
    char buf[64];
    /* pcTaskName tells you exactly which task overflowed */
    snprintf(buf, sizeof(buf), "!! STACK OVERFLOW in task: %s !!\r\n", pcTaskName);
    HAL_UART_Transmit(&huart2, (uint8_t *)buf, strlen(buf), HAL_MAX_DELAY);
    while (1);
}

/* This recursive function eats stack on every call */
static void stack_eater(uint32_t depth)
{
    volatile uint8_t big_array[64];   /* 64 bytes consumed per call */
    big_array[0] = (uint8_t)depth;    /* prevent optimizer removing it */

    char buf[32];
    snprintf(buf, sizeof(buf), "depth=%lu\r\n", depth);
    uart_print(buf);

    vTaskDelay(pdMS_TO_TICKS(100));   /* small delay so you can see output */

    stack_eater(depth + 1);           /* recurse forever → stack overflow */
}

static void vTaskADC(void *pvParameters)
{
    (void)pvParameters;
    uint32_t raw, voltage_mV;

    uart_print("ADC task started\r\n");

    /* Print watermark before overflow */
    char buf[48];
    snprintf(buf, sizeof(buf), "ADC stack watermark: %u words\r\n",
             uxTaskGetStackHighWaterMark(NULL));
    uart_print(buf);

    HAL_ADC_Start(&hadc1);

    for (;;)
    {
        if (HAL_ADC_PollForConversion(&hadc1, 100) == HAL_OK)
        {
            raw        = HAL_ADC_GetValue(&hadc1);
            voltage_mV = (raw * 3300UL) / 4095UL;
            xQueueSend(adcQueue, &voltage_mV, 0);
        }
        vTaskDelay(pdMS_TO_TICKS(50));
    }
}

static void vTaskDisplay(void *pvParameters)
{
    (void)pvParameters;
    uint32_t voltage_mV;
    char buf[32];

    uart_print("DISP task started\r\n");

    /* Intentionally eat stack via recursion — overflow will trigger here */
    stack_eater(0);

    /* Never reached */
    for (;;)
    {
        if (xQueueReceive(adcQueue, &voltage_mV, portMAX_DELAY) == pdPASS)
        {
            int len = snprintf(buf, sizeof(buf), "ADC: %4lu mV\r\n", voltage_mV);
            HAL_UART_Transmit(&huart2, (uint8_t *)buf, (uint16_t)len, HAL_MAX_DELAY);
        }
    }
}
