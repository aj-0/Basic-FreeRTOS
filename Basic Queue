int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_ADC1_Init();
    MX_USART2_UART_Init();

    /* USER CODE BEGIN 2 */
    adcQueue = xQueueCreate(10, sizeof(uint32_t));
    if (adcQueue == NULL)
    {
        uart_print("Queue FAILED\r\n");
        Error_Handler();
    }
    uart_print("Queue OK\r\n");

    HAL_ADC_Start(&hadc1);

    xTaskCreate(vTaskADC,     "ADC",  256, NULL, 5, NULL);
    xTaskCreate(vTaskDisplay, "DISP", 80,  NULL, 4, NULL);

    /* USER CODE END 2 */

    vTaskStartScheduler();
    while (1) { }
}

