#include "main.h"

/* USER CODE BEGIN Includes */
#include "FreeRTOS.h"
#include "task.h"
/* USER CODE END Includes */

/* USER CODE BEGIN PV */
TaskHandle_t Task1Handle = NULL;
TaskHandle_t Task2Handle = NULL;

volatile uint32_t counter1 = 0;
volatile uint32_t counter2 = 0;
/* USER CODE END PV */

/* Private function prototypes */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);

/* USER CODE BEGIN PFP */
void Task1_Counter(void *argument);
void Task2_Counter(void *argument);
/* USER CODE END PFP */

int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();

  /* USER CODE BEGIN 2 */
  xTaskCreate(Task1_Counter, "Task1", 128, NULL, 2, &Task1Handle);
  xTaskCreate(Task2_Counter, "Task2", 128, NULL, 2, &Task2Handle);

  vTaskStartScheduler();
  /* USER CODE END 2 */

  while (1) {}
}

/* USER CODE BEGIN 4 */

void Task1_Counter(void *argument)
{
  for(;;)
  {
    counter1++;
    HAL_GPIO_TogglePin(GPIOC, GPIO_PIN_13);  // LED toggles every 500ms
    vTaskDelay(pdMS_TO_TICKS(500));
  }
}

void Task2_Counter(void *argument)
{
  for(;;)
  {
    counter2++;
    // runs faster, every 200ms
    vTaskDelay(pdMS_TO_TICKS(200));
  }
}

